# =============================================================================
# Claro y Simple — Módulo 1: Ingesta y Extracción
# Archivo de ejemplo de variables de entorno (.env)
# Copiar a .env y ajustar según el entorno activo.
# =============================================================================

# --- Entorno ---
# Modo del entorno: "localstack" (LocalStack), "development" (AWS dev), "production" (AWS prod)
ENVIRONMENT=

# --- AWS ---
# Región AWS donde se despliega el módulo (ej: us-east-1)
AWS_REGION=
# Región AWS por defecto (usada también por SDKs locales)
AWS_DEFAULT_REGION=

# --- LocalStack (solo cuando ENVIRONMENT=localstack) ---
# URL del servicio LocalStack (ej: http://localhost:4566)
AWS_ENDPOINT_URL=

# --- Credenciales AWS (solo para desarrollo local / LocalStack) ---
# Las credenciales "test"/"test" son las que acepta LocalStack por defecto.
# En AWS real, usar credenciales de IAM.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Recursos AWS ---
# Nombre de la tabla DynamoDB donde se persisten los resultados de extracción
DYNAMODB_TABLE_NAME=
# Nombre del bucket S3 donde se almacenan los PDFs subidos
S3_BUCKET_NAME=

# --- Logging ---
# Nivel de log: INFO (por defecto), DEBUG (trazas detalladas)
LOG_LEVEL=
