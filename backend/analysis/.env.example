# =============================================================================
# Claro y Simple — Módulo 2: Motor de Análisis
# Archivo de ejemplo de variables de entorno (.env)
# Copiar a .env y ajustar según el entorno activo.
# =============================================================================

# --- Entorno ---
# Modo del entorno: "localstack" (LocalStack), "development" (AWS dev), "production" (AWS prod)
ENVIRONMENT=localstack

# --- AWS ---
# Región AWS (solo para desarrollo local / LocalStack; Lambda la provee automáticamente en prod)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# --- LocalStack (solo cuando ENVIRONMENT=localstack) ---
# URL del servicio LocalStack (ej: http://localhost:4566)
AWS_ENDPOINT_URL=http://localhost:4566

# --- Credenciales AWS (solo para desarrollo local / LocalStack) ---
# Las credenciales "test"/"test" son las que acepta LocalStack por defecto.
# En AWS real, usar credenciales de IAM.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Recursos AWS ---
# Nombre de la tabla DynamoDB de extracciones (Contrato 1, leída por este módulo)
EXTRACTIONS_TABLE_NAME=ContractExtractions
# Nombre de la tabla DynamoDB de análisis (Contrato 2, escrita por este módulo)
ANALYSES_TABLE_NAME=ContractAnalyses

# --- Bedrock ---
# Identificador del modelo en Amazon Bedrock (revisar catálogo al momento de implementar)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Timeout en segundos para la invocación a Bedrock
BEDROCK_TIMEOUT_SECONDS=45
# Límite máximo de caracteres del raw_text para el prompt
MAX_CONTEXT_CHARS=150000

# --- Logging ---
# Nivel de log: INFO (por defecto en producción), DEBUG (trazas detalladas)
LOG_LEVEL=INFO
